{
  "name": "nozomi-hunter",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:clean": "npm run clean && npm run dev",
    "dev:mobile": "next dev --hostname 0.0.0.0 --experimental-https",
    "clean": "node -e \"const fs=require('fs');for (const p of ['.next','node_modules/.cache'])try{fs.rmSync(p,{recursive:true,force:true});console.log('removed '+p)}catch(e){if(e.code!=='ENOENT')throw e}\"",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "check:architecture": "node scripts/check-architecture.mjs",
    "check:gdd-governance": "node scripts/check-gdd-governance.mjs",
    "check:visual": "node scripts/visual-audit.mjs",
    "ingest:content": "tsx scripts/ingest-content.ts",
    "ingest:assets": "tsx scripts/ingest-assets.ts",
    "generate:assets": "node scripts/generate-placeholder-assets.mjs",
    "generate:content-seeds": "node scripts/generate-content-seeds.mjs",
    "convert:webp": "node scripts/convert-png-to-webp.mjs",
    "verify:deploy": "node scripts/verify-deploy.mjs",
    "smoke:routes": "node scripts/smoke-routes.mjs",
    "check:theme": "node scripts/verify-theme-parity.mjs && node scripts/verify-no-hardcoded-ui-colors.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "supabase": "supabase",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:status": "supabase status",
    "db:reset": "supabase db reset",
    "db:push": "supabase db push --yes",
    "db:diff": "supabase db diff -f",
    "db:migration:new": "supabase migration new",
    "ingest:jmdict": "tsx scripts/ingest-jmdict.ts",
    "build:curated": "tsx scripts/extract-jmdict-curated.ts --"
  },
  "dependencies": {
    "@fontsource/barlow-condensed": "^5.2.8",
    "@fontsource/dm-sans": "^5.2.8",
    "@fontsource/noto-sans-jp": "^5.2.9",
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.49.1",
    "framer-motion": "^12.6.3",
    "next": "^15.2.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.2",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@tailwindcss/postcss": "^4.0.17",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "eslint": "^9.22.0",
    "eslint-config-next": "^15.2.4",
    "sharp": "^0.34.5",
    "supabase": "^2.101.0",
    "tailwindcss": "^4.0.17",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^4.1.7"
  }
}
