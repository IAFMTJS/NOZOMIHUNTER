# Supabase (required) — https://supabase.com
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Optional: show "Enter as Guest" button (requires Supabase anonymous auth enabled)
# NEXT_PUBLIC_ENABLE_GUEST_AUTH=false

# Optional: speech debug logs in browser console
# NEXT_PUBLIC_SPEECH_DEBUG=true

# Optional: bulk JMDict ingest script only (Settings → API → service_role)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Web Push (PWA invasion alerts — delivery via GitHub Actions)
# Generate: npx web-push generate-vapid-keys
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
# GitHub repo secrets (Actions): VAPID_PUBLIC_KEY, VAPID_PRIVATE_KEY, VAPID_SUBJECT (mailto:you@domain)
